# Optional when the frontend posts to another Vercel project instead of this one
VITE_LEAD_WEBHOOK_URL=https://your-project.vercel.app/api/discord-webhook
# Server-side secrets for the local Vercel API route
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/WEBHOOK_ID/WEBHOOK_TOKEN
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
# Compatibility fallback if your existing Vercel project still uses the old env name
VITE_GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
